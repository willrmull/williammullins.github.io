{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/blog/layout,_N_T_/blog/Infographic/layout,_N_T_/blog/Infographic/page,_N_T_/blog/Infographic"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/blog/Infographic/__PAGE__",
    "/blog/Infographic",
    "/blog",
    "/_index",
    "/_head"
  ]
}